# Firebase 設定（複製此檔案為 .env 並填入你的值）
# 取得方式：Firebase Console → 專案設定 → 你的應用程式

EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Google Cloud TTS（生成真實粵語音檔用）
# 申請：https://console.cloud.google.com/apis/credentials
# 啟用：Cloud Text-to-Speech API
# 用途：執行 npm run gen:audio 生成 assets/audio/cantonese/*.mp3
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here
